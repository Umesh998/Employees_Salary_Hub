@model IEnumerable<PayrollBatch>
@{
    ViewData["Title"] = "Payroll Batches";
}

<div class="batch-wrapper">

    <div class="page-header">
        <div>
            <h1>Payroll Batches</h1>
            <p class="subtitle">@Model.Count() batch(es) in total.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="Upload" asp-action="Index" class="btn btn-primary">⬆ Upload New</a>
            <a asp-action="Index" class="btn btn-outline">← Dashboard</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">⚠️ @TempData["Error"]</div>
    }

    @if (Model.Any())
    {
        <div class="card">
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Period</th>
                            <th>Slips</th>
                            <th>Release Date</th>
                            <th>Created At</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 1;
                        }
                        @foreach (var batch in Model)
                        {
                            var slipCount = batch.SalarySlips?.Count ?? 0;
                            var isReleased = batch.IsPublished && batch.ReleaseDate <= DateTime.UtcNow;

                            <tr>
                                <td class="text-muted">@i++</td>
                                <td><strong>@batch.Month / @batch.Year</strong></td>
                                <td>
                                    <span class="slip-count">@slipCount slip@(slipCount != 1 ? "s" : "")</span>
                                </td>
                                <td>@batch.ReleaseDate.ToString("dd MMM yyyy, HH:mm")</td>
                                <td class="text-muted">@batch.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (isReleased)
                                    {
                                        <span class="badge badge-green">Published</span>
                                    }
                                    else if (batch.IsPublished)
                                    {
                                        <span class="badge badge-blue">Scheduled</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-gray">Draft</span>
                                    }
                                </td>
                                <td>
                                    @if (!batch.IsPublished)
                                    {
                                        <form asp-action="Publish" asp-route-id="@batch.Id"
                                              method="post" style="display:inline"
                                              onsubmit="return confirm('Publish batch for @batch.Month/@batch.Year? This will make slips visible to employees after the release date.')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                🚀 Publish
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">📦</div>
            <h3>No Payroll Batches Yet</h3>
            <p>Upload an Excel file to create your first payroll batch.</p>
            <a asp-controller="Upload" asp-action="Index" class="btn btn-primary">⬆ Upload Payroll</a>
        </div>
    }
</div>

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #f4f6fb;
        color: #333;
    }

    .batch-wrapper {
        max-width: 1100px;
        margin: 2rem auto;
        padding: 0 1.5rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.8rem;
    }

        .page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
        }

    .subtitle {
        color: #666;
        font-size: 0.9rem;
        margin-top: 0.3rem;
    }

    .header-actions {
        display: flex;
        gap: 0.75rem;
    }

    .alert {
        border-radius: 8px;
        padding: 0.85rem 1.2rem;
        font-size: 0.9rem;
        margin-bottom: 1.2rem;
    }

    .alert-success {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .alert-danger {
        background: #fce4ec;
        color: #c62828;
    }

    .card {
        background: white;
        border-radius: 12px;
        padding: 1.6rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }

    .table-wrapper {
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }

        .data-table th {
            background: #f0f4ff;
            padding: 0.7rem 1rem;
            text-align: left;
            font-weight: 600;
            color: #555;
            border-bottom: 2px solid #dde3f0;
        }

        .data-table td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .data-table tr:last-child td {
            border-bottom: none;
        }

        .data-table tr:hover td {
            background: #fafbff;
        }

    .text-muted {
        color: #999;
        font-size: 0.82rem;
    }

    .slip-count {
        background: #f0f4ff;
        color: #1a73e8;
        padding: 0.2rem 0.6rem;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .badge {
        display: inline-block;
        padding: 0.22rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-green {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .badge-blue {
        background: #e3f2fd;
        color: #1565c0;
    }

    .badge-gray {
        background: #f5f5f5;
        color: #757575;
    }

    .btn {
        display: inline-block;
        padding: 0.5rem 1.1rem;
        border-radius: 6px;
        font-size: 0.9rem;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: 0.2s;
        font-weight: 500;
    }

    .btn-outline {
        border: 2px solid #1a73e8;
        color: #1a73e8;
        background: transparent;
    }

        .btn-outline:hover {
            background: #1a73e8;
            color: white;
        }

    .btn-primary {
        background: #1a73e8;
        color: white;
        font-weight: 600;
    }

        .btn-primary:hover {
            background: #1558c0;
        }

    .btn-sm {
        padding: 0.35rem 0.85rem;
        font-size: 0.82rem;
    }

    .empty-state {
        background: white;
        border-radius: 14px;
        padding: 4rem 2rem;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
    }
</style>
