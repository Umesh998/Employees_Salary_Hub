@model Employees_Salary_Hub.ViewModels.Employee.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="cp-wrapper">

    <div class="page-header">
        <h1>Change Password</h1>
        <a asp-action="Index" class="btn btn-outline">← Back to Dashboard</a>
    </div>

    <div class="form-card">

        <div class="form-icon">🔒</div>
        <p class="form-subtitle">Choose a strong password to keep your account secure.</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">✅ @TempData["Success"]</div>
        }

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <form asp-action="ChangePassword" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="CurrentPassword">Current Password</label>
                <div class="input-wrapper">
                    <input asp-for="CurrentPassword" type="password"
                           class="form-input" placeholder="Enter your current password"
                           id="currentPwd" />
                    <span class="toggle-eye" onclick="toggleVisibility('currentPwd', this)">👁</span>
                </div>
                <span asp-validation-for="CurrentPassword" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <div class="input-wrapper">
                    <input asp-for="NewPassword" type="password"
                           class="form-input" placeholder="Enter a new password"
                           id="newPwd" />
                    <span class="toggle-eye" onclick="toggleVisibility('newPwd', this)">👁</span>
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmNewPassword">Confirm New Password</label>
                <div class="input-wrapper">
                    <input asp-for="ConfirmNewPassword" type="password"
                           class="form-input" placeholder="Re-enter the new password"
                           id="confirmPwd" />
                    <span class="toggle-eye" onclick="toggleVisibility('confirmPwd', this)">👁</span>
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="field-error"></span>
            </div>

            <!-- Password Strength Indicator -->
            <div class="strength-wrapper">
                <div class="strength-bar">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
                <span class="strength-label" id="strengthLabel">Enter a new password</span>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Update Password</button>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleVisibility(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text'; icon.style.opacity = '0.5';
            } else {
                input.type = 'password'; icon.style.opacity = '1';
            }
        }

        document.getElementById('newPwd').addEventListener('input', function () {
            const val = this.value;
            const fill = document.getElementById('strengthFill');
            const label = document.getElementById('strengthLabel');
            let score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { color: '#e53935', text: 'Very Weak' },
                { color: '#fb8c00', text: 'Weak' },
                { color: '#fdd835', text: 'Fair' },
                { color: '#43a047', text: 'Strong' },
                { color: '#1b5e20', text: 'Very Strong' },
            ];
            const lvl = val.length === 0 ? null : levels[score];
            fill.style.width = val.length === 0 ? '0%' : `${(score + 1) * 20}%`;
            fill.style.background = lvl ? lvl.color : 'transparent';
            label.textContent = lvl ? lvl.text : 'Enter a new password';
        });
    </script>
}

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #f4f6fb;
        color: #333;
    }

    .cp-wrapper {
        max-width: 520px;
        margin: 2.5rem auto;
        padding: 0 1.5rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

        .page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
        }

    .form-card {
        background: white;
        border-radius: 14px;
        padding: 2.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }

    .form-icon {
        font-size: 2.5rem;
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .form-subtitle {
        text-align: center;
        color: #666;
        font-size: 0.92rem;
        margin-bottom: 1.8rem;
    }

    .alert {
        border-radius: 8px;
        padding: 0.85rem 1.2rem;
        font-size: 0.9rem;
        margin-bottom: 1.2rem;
    }

    .alert-success {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .alert-danger {
        background: #fce4ec;
        color: #c62828;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-bottom: 1.2rem;
    }

        .form-group label {
            font-size: 0.88rem;
            font-weight: 600;
            color: #444;
        }

    .input-wrapper {
        position: relative;
    }

    .form-input {
        width: 100%;
        padding: 0.65rem 2.5rem 0.65rem 0.9rem;
        border: 1.5px solid #dde3f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: border-color 0.2s;
        outline: none;
    }

        .form-input:focus {
            border-color: #1a73e8;
        }

    .toggle-eye {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        font-size: 1rem;
        user-select: none;
    }

    .field-error {
        color: #e53935;
        font-size: 0.8rem;
    }

    .strength-wrapper {
        margin-bottom: 1.5rem;
    }

    .strength-bar {
        height: 6px;
        background: #eee;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 0.4rem;
    }

    .strength-fill {
        height: 100%;
        width: 0%;
        border-radius: 4px;
        transition: all 0.3s;
    }

    .strength-label {
        font-size: 0.78rem;
        color: #888;
    }

    .btn {
        display: inline-block;
        padding: 0.6rem 1.4rem;
        border-radius: 8px;
        font-size: 0.95rem;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: 0.2s;
    }

    .btn-outline {
        border: 2px solid #1a73e8;
        color: #1a73e8;
        background: transparent;
    }

        .btn-outline:hover {
            background: #1a73e8;
            color: white;
        }

    .btn-primary {
        background: #1a73e8;
        color: white;
        font-weight: 600;
    }

        .btn-primary:hover {
            background: #1558c0;
        }

    .btn-full {
        width: 100%;
        text-align: center;
        padding: 0.75rem;
    }
</style>
