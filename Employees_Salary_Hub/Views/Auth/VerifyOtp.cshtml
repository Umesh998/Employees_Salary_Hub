        <form asp-action="VerifyOtp" method="post" id="otpForm">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />
            <input asp-for="OtpCode" type="hidden" id="OtpCode" />

            <div class="otp-wrapper">
                @for (int i = 0; i < 6; i++)
                {
                    <input class="otp-box" type="text" maxlength="1" inputmode="numeric" />
                }
            </div>

            <button type="submit" class="btn">Verify OTP →</button>
        </form>

        <script>
                    const boxes       = document.querySelectorAll('.otp-box');
                    const hiddenInput = document.getElementById('OtpCode');
                    const form        = document.getElementById('otpForm');

                    boxes.forEach((box, i) => {
                        box.addEventListener('input', () => {
                            box.value = box.value.replace(/\D/g, '').slice(-1);
                            if (box.value && i < boxes.length - 1) boxes[i + 1].focus();
                            syncHidden();
                        });

                        box.addEventListener('keydown', e => {
                            if (e.key === 'Backspace' && !box.value && i > 0) boxes[i - 1].focus();
                        });

                        box.addEventListener('paste', e => {
                            e.preventDefault();
                            const pasted = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 6);
                            [...pasted].forEach((ch, j) => { if (boxes[j]) boxes[j].value = ch; });
                            syncHidden();
                            boxes[Math.min(pasted.length, 5)].focus();
                        });
                    });

                    function syncHidden() {
                        hiddenInput.value = [...boxes].map(b => b.value).join('');
                    }

                    // ✅ Sync hidden field RIGHT BEFORE form submits
                    form.addEventListener('submit', (e) => {
                        syncHidden();

                        // Validate OTP is 6 digits before submitting
                        if (hiddenInput.value.length !== 6) {
                            e.preventDefault();
                            alert('Please enter all 6 digits.');
                            return;
                        }

                        console.log('Submitting OTP:', hiddenInput.value); // check browser console
                    });
        </script>


</body>
</html>
